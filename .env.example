# ======================================
# Ink & Prompt 后端环境变量配置模板
# ======================================
#
# 使用说明：
# 1. 复制此文件并重命名为 backend/.env
# 2. 填写实际的配置值（特别是 API Keys）
# 3. 确保 .env 文件不要提交到版本控制
#
# 注意：前端环境变量在 frontend/.env.example 中配置
#

# ======================================
# 数据库配置
# ======================================
# Docker 部署使用 PostgreSQL（推荐用于生产环境）
DATABASE_URL=postgresql://inkprompt:inkprompt_password_change_in_production@localhost:5432/inkprompt
# 本地开发可使用 SQLite：sqlite:///./inkprompt.db

# PostgreSQL 配置（仅在使用 Docker Compose 时需要）
# 注意：生产环境请修改默认密码！
POSTGRES_DB=inkprompt
POSTGRES_USER=inkprompt
POSTGRES_PASSWORD=inkprompt_password_change_in_production

# ======================================
# Supabase 认证配置
# ======================================
# 从 Supabase 项目设置中获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ======================================
# LLM API 配置（OpenRouter）
# ======================================
# OpenRouter API Key（从 https://openrouter.ai 获取）
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter API 地址
OPENAI_API_BASE=https://openrouter.ai/api/v1

# 默认模型（可选值：openai/gpt-4, openai/gpt-3.5-turbo, anthropic/claude-3-sonnet 等）
DEFAULT_MODEL=openai/gpt-4

# LangChain 配置（可选，用于调试）
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# ======================================
# 模型调用限制
# ======================================
# 默认最大 Token 数
MAX_TOKENS_DEFAULT=2000

# 默认温度参数（0-1）
TEMPERATURE_DEFAULT=0.7

# 模型调用超时时间（秒）
MODEL_TIMEOUT=30

# 每个用户的速率限制（次/小时）
RATE_LIMIT_PER_USER=100

# ======================================
# 应用设置
# ======================================
APP_NAME=Ink & Prompt
APP_VERSION=0.1.0

# 调试模式（生产环境设置为 false）
DEBUG=false

# 允许的 CORS 来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
